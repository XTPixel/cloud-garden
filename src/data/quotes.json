[
  {
    "text": "风从很远的地方来，也会在你手边停一会儿。",
    "source": "云外庭院"
  },
  {
    "text": "慢慢来，比较快。",
    "source": "个人语录"
  },
  {
    "text": "把注意力放回手上的事情。",
    "source": "每日提醒"
  },
  {
    "text": "生活不是进度条，也可以是花园。",
    "source": "数字花园"
  },
  {
    "text": "先让它存在，再让它变好。",
    "source": "创作原则"
  },
  {
    "text": "给今天留一点柔软的空白。",
    "source": "心境备忘"
  }
]
